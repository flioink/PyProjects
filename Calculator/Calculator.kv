<Button>
    size_hint: 0.2, 0.2
    background_normal: ""
    background_color: (2/255, 10/255, 24/ 255, 1)

<CalculatorWidget>
    BoxLayout:
        orientation: "vertical"
        size: root.width, root.height

        TextInput:
            id: inputBox
            text: "0"
            font_name: "Lcd.ttf"
            font_size: 80
            multiline: False
            halign: "right"
            size_hint: 1, 0.2
            background_color: (20/255, 20/255, 30/ 255)
            foreground_color: (1, 1, 1, 1)

        GridLayout:
            cols: 4
            rows: 5
             # row 1
            Button:
                text: "%"
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.signs(self)
            Button:
                text: "C"
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.clear()
            Button:
                text: u"\u00AB"
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.removeLast()
            Button:
                text: "/"
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.signs(self)
            # row 2
            Button:
                text: "7"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: "8"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: "9"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: "*"
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.signs(self)
            # row 3
            Button:
                text: "4"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: "5"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: "6"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: "-"
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.signs(self)
            # row 4
            Button:
                text: "1"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: "2"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: "3"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: "+"
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.signs(self)
            # row 5
            Button:
                text: "+/-"
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.posNeg()
            Button:
                text: "0"
                font_size: 32
                on_press: root.buttonValue(self)
            Button:
                text: ","
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.dot()
            Button:
                text: "="
                font_size: 32
                background_color: (14/255, 73/255, 176/255, 1)
                on_press: root.results()











